# --- Database (isolated: separate DB, may share the platform's Atlas cluster) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_CHATBOT_DB=chatbot

# --- Platform integration (server-to-server) ---
# Base URL of the Single Solution platform that issues product access tokens.
PLATFORM_API_URL=http://localhost:3000
# Shared secret for the platform's internal endpoints. MUST match the platform's
# INTERNAL_API_SECRET so token verification + usage metering are authorized.
INTERNAL_API_SECRET=change-me-min-16-chars
# Signs in-product admin dashboard sessions after SSO exchange. MUST match the
# platform's SSO_SIGNING_SECRET in production.
SSO_SIGNING_SECRET=change-me-sso-signing-secret
# Signs short-lived embed widget sessions (bearer header, not cookies).
# MUST match the platform's EMBED_SIGNING_SECRET in production.
EMBED_SIGNING_SECRET=change-me-embed-signing-secret

# --- Upstash Redis (required in production for distributed rate limits/caches) ---
# Create a REST database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Assistant (optional overrides) ---
# CHAT_ASSISTANT_ENABLED=true
# CHAT_ASSISTANT_NAME=Chat Support
# CHAT_WELCOME_MESSAGE=Hi! How can we help you today?

# --- Vercel Cron (required in production) ---
# Generate: openssl rand -hex 24
CRON_SECRET=change-me-cron-secret-min-16-chars

# --- Observability ---
LOG_LEVEL=debug
# ERROR_TRACKING_DSN=https://example.com/your-project

# --- Demo data retention (days) for public sandbox cleanup cron ---
DEMO_DATA_RETENTION_DAYS=30

# Catalog slug used when listing tenant databases for migrations
# PRODUCT_CATALOG_SLUG=ecommerce-chatbot

# Restricted demo tenant token issued by scripts/seed-demo.mjs. Injected into
# /public-demo and /demo (without ?token=) server-side — not a privileged secret.
# Domain allowlist on the token must include this product host and localhost.
# PUBLIC_DEMO_PRODUCT_TOKEN=pk_live_xxx

# Merchants embed the widget on their own site with one line (no env needed):
#   <script src="https://THIS-PRODUCT-HOST/embed.js" data-product-token="pk_live_xxx" async></script>
# The token's allowed domains must include the merchant's site host.
