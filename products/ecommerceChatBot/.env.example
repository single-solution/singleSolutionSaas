# --- Database (isolated: separate DB, may share the platform's Atlas cluster) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_CHATBOT_DB=chatbot

# --- Platform integration (server-to-server) ---
# Base URL of the Single Solution platform that issues product access tokens.
PLATFORM_API_URL=http://localhost:3000
# Shared secret for the platform's internal endpoints. MUST match the platform's
# INTERNAL_API_SECRET so token verification + usage metering are authorized.
INTERNAL_API_SECRET=change-me-min-16-chars

# --- Assistant (optional overrides) ---
# CHAT_ASSISTANT_ENABLED=true
# CHAT_ASSISTANT_NAME=Chat Support
# CHAT_WELCOME_MESSAGE=Hi! How can we help you today?

# --- Local demo only ---
# A valid product access token so the demo page can activate the widget.
# Issue the token in the platform with `localhost` in its allowed domains,
# otherwise the widget is blocked (tokens are domain-bound; empty = blocked).
# NEXT_PUBLIC_DEMO_PRODUCT_TOKEN=pk_live_xxx

# Merchants embed the widget on their own site with one line (no env needed):
#   <script src="https://THIS-PRODUCT-HOST/embed.js" data-product-token="pk_live_xxx" async></script>
# The token's allowed domains must include the merchant's site host.
