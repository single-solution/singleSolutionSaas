# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/
MONGODB_PLATFORM_DB=platform

JWT_SECRET=change-me-to-at-least-32-characters-long
INTERNAL_API_SECRET=change-me-internal-secret
SSO_SIGNING_SECRET=change-me-sso-signing-secret
PREVIEW_SIGNING_SECRET=change-me-preview-signing-secret
EMBED_SIGNING_SECRET=change-me-embed-signing-secret

# First-run bootstrap when users collection is empty
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Public base URL used to build invite and recovery links in outbound email
APP_URL=http://localhost:3000

# Upstash Redis (required in production for distributed rate limits)
# Create a REST database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron (required in production)
# Generate: openssl rand -hex 24
CRON_SECRET=change-me-cron-secret-min-16-chars

# Structured logging / optional error tracking
LOG_LEVEL=debug
# ERROR_TRACKING_DSN=https://example.com/your-project

ECOMMERCE_CHATBOT_PUBLIC_URL=http://localhost:3002

# Config secret encryption (AES-256-GCM). Generate a 32-byte key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CONFIG_ENCRYPTION_KEYS={"v1":"REPLACE_WITH_BASE64_32_BYTE_KEY"}
CONFIG_ENCRYPTION_ACTIVE_KEY_ID=v1

# SMTP for transactional email (invites, recovery). Leave unset to disable sending;
# the portal then falls back to a copyable invite link.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Single Solution <no-reply@example.com>"
EMAIL_REPLY_TO=support@example.com
