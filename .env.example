# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/
MONGODB_PLATFORM_DB=platform

JWT_SECRET=change-me-to-at-least-32-characters-long
INTERNAL_API_SECRET=change-me-internal-secret

# First-run bootstrap when users collection is empty
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Public base URL used to build invite links in outbound email
APP_URL=http://localhost:3000

# Guest "Try live demo" link on /login (ecommerce chatbot public sandbox)
ECOMMERCE_CHATBOT_PUBLIC_URL=http://localhost:3002

# SMTP for transactional email (invites). Leave unset to disable sending;
# the portal then falls back to a copyable invite link.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Single Solution <no-reply@example.com>"
EMAIL_REPLY_TO=support@example.com
